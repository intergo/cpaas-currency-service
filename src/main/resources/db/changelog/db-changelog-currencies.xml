<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-currencies-table" author="alex">
        <createTable tableName="currencies">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="currency_name" type="varchar(10)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="base_currency" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="available" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp">
              <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="create-initial-currencies" author="alex">
      <preConditions onFail="MARK_RAN">
        <tableExists tableName="currencies"/>
        <sqlCheck expectedResult="0">
            SELECT COUNT(*) FROM currencies
            WHERE currency_name IN ('EUR', 'USD')
        </sqlCheck>
      </preConditions>

      <insert tableName="currencies">
        <column name="currency_name" value="EUR"/>
        <column name="base_currency" valueBoolean="true"/>
        <column name="available" valueBoolean="true"/>
        <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
      </insert>

      <insert tableName="currencies">
        <column name="currency_name" value="USD"/>
        <column name="base_currency" valueBoolean="false"/>
        <column name="available" valueBoolean="true"/>
        <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
      </insert>

      <insert tableName="currencies">
        <column name="currency_name" value="CAD"/>
        <column name="base_currency" valueBoolean="false"/>
        <column name="available" valueBoolean="true"/>
        <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
      </insert>
  </changeSet>
</databaseChangeLog>
